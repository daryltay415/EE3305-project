<mujoco model="robot scene">
  <compiler angle="radian"/>
  <option timestep="0.0025"/>

  <include file="pogo-stick.xml"/>
  <include file="posed-humanoid.xml"/>

  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <!-- <global azimuth="120" elevation="-20"/> -->
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.8 0.8 0.8" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <texture type="2d" name="wheel_texture" builtin="checker" mark="edge" rgb1="0.0 0.0 0.0" rgb2="0.2 0.2 0.2"
      markrgb="0.3 0.3 0.3" width="300" height="300"/>
    <material name="wheel_material" texture="wheel_texture" texuniform="true" texrepeat="5 5"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="-0.5 -0.5 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane"/>
  </worldbody>

  <contact>
    <pair geom1="floor" geom2="pogo_lower" friction="0.4 0.4 0.07 0.001 0.001"/>
    <exclude body1="pelvis" body2="pogo_upper"/>
  </contact>

  <equality>
    <connect name="left_grasp" site1="left_grip" site2="left_hand"/>
    <connect name="right_grasp" site1="right_grip" site2="right_hand"/>
    <!-- <connect name="left_foothold" site1="left_foothold" site2="left_foot"/>
    <connect name="right_foothold" site1="right_foothold" site2="right_foot"/> -->
  </equality>

</mujoco>
